rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's tenantId
    function getUserTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    // Users Collection: Support registration bootstrap
    match /users/{uid} {
      // Allow read if it's the user's own document
      allow read: if request.auth != null && request.auth.uid == uid;
      
      // Allow create if the user is authenticated, 
      // the UID matches, and they don't already have a profile.
      allow create: if request.auth != null && request.auth.uid == uid;
      
      // Admin/Staff updates (needs future refined logic)
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Tenants Collection and sub-collections
    match /tenants/{tenantId} {
      allow read: if true; // Allow public to see business name/config
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      
      // Services: Public read, Owner write
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      }

      // Appointments: Public create, Owner full access
      match /appointments/{appId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      }
    }
  }
}
