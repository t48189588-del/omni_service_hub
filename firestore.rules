rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's tenantId
    function getUserTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    // Users Collection: Users can only read their own metadata document
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only manageable via secure backend admin scripts
    }

    // Tenants Collection and sub-collections
    match /tenants/{tenantId} {
      // Allow access if the user's assigned tenantId matches the document's tenantId
      allow read, write: if request.auth != null && getUserTenantId() == tenantId;
      
      // Protect any nested sub-collections (e.g., /customers, /services) under the tenant
      match /{document=**} {
        allow read, write: if request.auth != null && getUserTenantId() == tenantId;
      }
    }
  }
}
